# Copy to .env — never commit .env
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_POLLINATIONS_API_KEY=your_pollinations_api_key_here

# App URLs
APP_URL=http://127.0.0.1:3000
# Public URL returned in PDF download links (set to your server IP/domain in Docker/production)
PUBLIC_APP_URL=http://localhost:3000
EXPORT_RENDER_SECRET=dev-export-render-secret

# Kafka — local dev (broker on host)
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=ebook-generator
KAFKA_GROUP_ID=ebook-generator-newsletter-consumers
KAFKA_TOPIC_NEWSLETTER_PDF=NEWS_LETTER_PDF
KAFKA_TOPIC_NEWSLETTER_PDF_COMPLETED=NEWS_LETTER_PDF_COMPLETED
KAFKA_TOPIC_NEWSLETTER_PDF_FAILED=NEWS_LETTER_PDF_FAILED
KAFKAJS_NO_PARTITIONER_WARNING=1

# Docker only — set to your server's LAN/public IP so external services can reach Kafka on :9092
# KAFKA_ADVERTISED_HOST=192.168.1.50

# Cloudinary — Kafka consumer uploads PDFs here and returns public URLs
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PDF_FOLDER=newsletter-pdfs

# BullMQ (optional — large UI exports)
REDIS_URL=redis://127.0.0.1:6379
